# ─────────────────────────────────────────────────────────────────────────────
# MIXTRAN — Environment variables
#
# Copy this file to .env.local and fill in the real values.
# Never commit .env.local to version control.
#
# Rules:
#   NEXT_PUBLIC_*  → exposed to the browser (keep minimal)
#   NEXT_*         → server-side only (API routes, Server Components)
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
# Public canonical URL — used for sitemap, robots.txt, and OG metadata.
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ── AWS credentials ──────────────────────────────────────────────────────────
# IAM user with least-privilege access to DynamoDB, SES, and S3.
# Use NEXT_ prefix to avoid Amplify's reserved AWS_* restriction.
# In production: set these in Amplify Console → Environment variables.
# Locally: use your existing AWS CLI profile instead (AWS_PROFILE or default).
NEXT_AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
NEXT_AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AWS region ────────────────────────────────────────────────────────────────
# All AWS services must live in the same region.
NEXT_AWS_REGION=us-east-1

# ── AWS Cognito ───────────────────────────────────────────────────────────────
# From: AWS Console → Cognito → User pools → <pool> → Overview
NEXT_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# From: Cognito → User pools → <pool> → App clients
NEXT_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Client secret — only set this if your App Client was created WITH a client secret.
# Leave blank (or remove) if the App Client has no secret (recommended for server-side apps).
NEXT_COGNITO_CLIENT_SECRET=

# ── Session cookie ────────────────────────────────────────────────────────────
# Name of the httpOnly cookie that stores the Cognito IdToken.
NEXT_SESSION_COOKIE_NAME=paint_session

# ── DynamoDB tables ───────────────────────────────────────────────────────────
# Table names must match what you created in AWS (see docs/aws-dynamodb-setup.md).
NEXT_DYNAMODB_TABLE_SLOTS=paint-slots
NEXT_DYNAMODB_TABLE_CONTACTS=paint-contacts
NEXT_DYNAMODB_TABLE_REVIEWS=paint-reviews
NEXT_DYNAMODB_TABLE_LANDING=paint-landing-config

# ── AWS SES ───────────────────────────────────────────────────────────────────
# Verified sender identity in SES (domain or email address).
NEXT_SES_FROM_EMAIL=noreply@yourdomain.com
# Admin inbox — receives new booking notifications.
NEXT_SES_ADMIN_EMAIL=admin@yourdomain.com

# ── AWS S3 + CloudFront ───────────────────────────────────────────────────────
# Bucket name for media uploads (product images, gallery, etc.).
NEXT_S3_BUCKET_NAME=paint-brand-media
# CloudFront distribution URL (no trailing slash) that serves the S3 bucket.
NEXT_S3_CLOUDFRONT_URL=https://xxxxxxxxxxxx.cloudfront.net
